# ─────────────────────────────────────────────────
# ZYNARA – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# MTN MoMo Developer Portal credentials
# Sign up at: https://momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=your_primary_key_here
MOMO_API_USER=your_api_user_uuid_here
MOMO_API_KEY=your_api_key_here

# "sandbox" for testing, or your country code for live (e.g. "mtnghana", "mtnuganda")
MOMO_ENV=sandbox

# Sandbox always uses EUR. Production: use your country currency code (e.g. GHS, UGX, XAF)
MOMO_CURRENCY=EUR

# MoMo API base URL
# Sandbox: https://sandbox.momodeveloper.mtn.com
# Production: https://proxy.momoapi.mtn.com
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# A long random secret string (used to sign stream tokens)
SECRET_KEY=replace-with-a-long-random-string

# Set to false in production
DEBUG=true
